# Gridwire — copy to .env and fill in

# Discord bot token (Discord Developer Portal -> your app -> Bot -> Token)
DISCORD_TOKEN=

# The channel to post schedule alerts into (right-click channel -> Copy Channel ID)
DISCORD_CHANNEL_ID=

# --- optional ---

# Pin the season to watch. Default: auto (Jan-Feb = last year's season, Mar+ = this year's)
#SEASON_YEAR=2026

# How often to poll, in minutes. Default: 30
#POLL_MINUTES=30

# Watch preseason games too (ESPN rung only). Default: off
#INCLUDE_PRESEASON=1

# Provider ladder order. Default: espn,nflverse,balldontlie
#PROVIDER_ORDER=espn,nflverse,balldontlie

# balldontlie NFL API key — enables the third provider rung
#BALLDONTLIE_API_KEY=

# Set to 0 to stop @everyone on alerts. Default: on
#MENTION_EVERYONE=1

# Channel for score-related slash commands (feature not built yet)
#DISCORD_SCORES_CHANNEL_ID=

# Where snapshots are stored. Default: ./data
#DATA_DIR=
